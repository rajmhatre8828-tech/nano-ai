{
  "expo": {
    "name": "Nano AI",
    "slug": "nano-ai",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "nano-ai",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.nano-ai",
      "infoPlist": {
        "NSSupportsLiveActivities": true,
        "NSMicrophoneUsageDescription": "We need access to your microphone for voice input",
        "NSSpeechRecognitionUsageDescription": "We need access to speech recognition for voice input",
        "NSPhotoLibraryUsageDescription": "This app does not access your photo library"
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "@bacons/apple-targets",
      "expo-speech-recognition"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "package": "com.anonymous.nanoai"
    }
  }
}